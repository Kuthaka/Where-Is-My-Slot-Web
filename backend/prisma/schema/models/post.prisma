model Post {
  id        String   @id @default(uuid())
  text      String   @db.Text
  image     String?
  tags      String[]
  location  String?
  views     Int      @default(0)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  likes     Like[]
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
