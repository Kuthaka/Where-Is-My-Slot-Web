model Business {
  id               String   @id @default(uuid())
  ownerId          String?  // Optional for unclaimed businesses
  
  // Basic Info
  name             String
  username         String?  @unique
  tagline          String?
  description      String?
  establishedYear  Int?
  gstNumber        String?

  // Contact Information
  contactPerson    String?
  phone            String?
  email            String?
  websiteUrl       String?
  whatsappNumber   String?
  mobileNumbers    String[]
  landlineNumbers  String[]
  emails           String[]
  
  // Location
  address          String?
  pincode          String?
  plotNo           String?
  buildingName     String?
  streetName       String?
  landmark         String?
  area             String?
  city             String?
  state            String?
  latitude         Float?
  longitude        Float?
  googleMapsUrl    String?

  // Operating
  timings          Json?
  
  // Categorization
  primaryCategory  String?
  subCategories    String[]
  
  // Features
  amenities        String[]
  parking          Json?
  
  // Media & Social
  logo             String?
  coverPhoto       String?
  images           String[]
  socialLinks      Json?

  // Status & Verification
  isVerified       Boolean  @default(false)
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner            User?    @relation(fields: [ownerId], references: [id])
  offers           Offer[]
  posts            Post[]
}
